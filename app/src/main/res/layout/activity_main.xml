<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context="com.test3.MainActivity">

    <!-- Background Decor -->
    <View
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:background="@drawable/bg_blob"
        android:alpha="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top AppBar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#66FFFFFF"
        android:elevation="4dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Memory Game"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/menuIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/historyIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_recent_history"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content (Menu) -->
    <ScrollView
        android:id="@+id/menuLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="Memory\nGame"
                android:textColor="@color/primary"
                android:textSize="72sp"
                android:lineSpacingExtra="-10dp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.6"
                android:letterSpacing="0.1"
                android:text="ENHANCE YOUR COGNITIVE FLOW"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:background="@drawable/glass_panel"
                android:padding="32dp">

                <TextView
                    android:id="@+id/selectDifficultyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Difficulty"
                    android:textColor="@color/primary_dim"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/difficultyGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_difficulty_container"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    app:layout_constraintTop_toBottomOf="@id/selectDifficultyLabel">

                    <TextView
                        android:id="@+id/easyMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_difficulty_selected"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="EASY 4X4"
                        android:textColor="@color/on_tertiary_container"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/mediumMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="MEDIUM 6X6"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hardMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="HARD 8X8"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/playNowButton"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_play_button"
                    android:text="PLAY NOW"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    app:layout_constraintTop_toBottomOf="@id/difficultyGroup" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="SETTINGS"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/playNowButton" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Quick Stats Bento -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:columnCount="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1,240" android:textColor="@color/on_surface" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HIGH SCORE" android:textColor="@color/on_surface_variant" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="@color/secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="42s" android:textColor="@color/on_surface" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BEST TIME" android:textColor="@color/on_surface_variant" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/star_on" app:tint="@color/tertiary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="@color/on_surface" android:textStyle="bold" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WINS TODAY" android:textColor="@color/on_surface_variant" android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                </LinearLayout>
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Game Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gameLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <!-- Stats Section (Tactile Ethereal) -->
        <LinearLayout
            android:id="@+id/gameStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/glass_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOVES" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.2"/>
                <TextView android:id="@+id/movesText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/primary" android:textSize="28sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_timer_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIME" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.2"/>
                <TextView android:id="@+id/timerText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="@color/primary" android:textSize="28sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/restartButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/glass_panel"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/stat_notify_sync" app:tint="@color/primary_dim"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESTART" android:textColor="@color/on_surface_variant" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Game Board -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_board_container"
            android:padding="12dp"
            app:layout_constraintBottom_toTopOf="@id/gameDifficultyButtons"
            app:layout_constraintTop_toBottomOf="@id/gameStats">
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                tools:listitem="@layout/card_item" />
        </FrameLayout>

        <!-- Footer Difficulty Select -->
        <LinearLayout
            android:id="@+id/gameDifficultyButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/gameEasy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_difficulty_pill"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="EASY"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/gameMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_difficulty_pill_active"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="MEDIUM"
                android:textColor="@color/on_tertiary_container"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/gameHard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_difficulty_pill"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="HARD"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Win Content (Modal Style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/winLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:elevation="10dp"
        android:padding="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_panel"
            android:padding="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Celebration Badge -->
            <FrameLayout
                android:id="@+id/celebrationBadge"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_nav_center"
                android:rotation="-6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/white" />
            </FrameLayout>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_difficulty_pill_active"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="NEW RECORD"
                android:textColor="@color/on_tertiary_container"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/celebrationBadge"
                app:layout_constraintTop_toTopOf="@id/celebrationBadge"
                android:translationX="10dp"
                android:translationY="-5dp"/>

            <TextView
                android:id="@+id/winTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="You Won!"
                android:textColor="@color/on_surface"
                android:textSize="48sp"
                android:fontFamily="sans-serif-black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/celebrationBadge" />

            <TextView
                android:id="@+id/winSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Incredible performance! You've successfully matched all the pairs."
                android:textColor="@color/on_surface_variant"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/winTitle" />

            <LinearLayout
                android:id="@+id/winStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/winSubtitle">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL MOVES" android:textColor="@color/primary_dim" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/winMovesText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textColor="@color/on_surface" android:textSize="32sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIME TAKEN" android:textColor="@color/primary_dim" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/winTimeText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0:42" android:textColor="@color/on_surface" android:textSize="32sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/playAgainButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_play_button"
                android:text="Play Again"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/winStats" />

            <Button
                android:id="@+id/winHomeButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_difficulty_container"
                android:text="Back to Home"
                android:textAllCaps="false"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/playAgainButton" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Navigation -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="#CCFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/outline" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="@color/outline" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/navPlay"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                
                <LinearLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_nav_center"
                    android:elevation="8dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLAY" android:textColor="@color/white" android:textSize="9sp" android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/navStats"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_info_details" app:tint="@color/outline" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STATS" android:textColor="@color/outline" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>